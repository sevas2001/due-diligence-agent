# ===== LLM (capa agnóstica vía OpenRouter, OpenAI-compatible) =====
# Consigue tu key en https://openrouter.ai/keys
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://openrouter.ai/api/v1
# Modelo: cualquiera de OpenRouter. Cambia aquí sin tocar código.
# Pruebas: google/gemini-2.5-flash (barato/rápido). Producción: anthropic/claude-sonnet-4.6
LLM_MODEL=google/gemini-2.5-flash
LLM_TEMPERATURE=0.2

# ===== Tools =====
# Búsqueda web en tiempo real: https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# ===== Base de datos (memoria persistente) =====
POSTGRES_USER=ddagent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=duediligence
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# URL completa (la usa SQLAlchemy). En docker-compose el host es "db".
DATABASE_URL=postgresql+psycopg2://ddagent:changeme@localhost:5432/duediligence

# ===== App =====
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
